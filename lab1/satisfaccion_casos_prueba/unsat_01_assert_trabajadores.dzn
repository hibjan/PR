% ============================================================
% INSAT-01 — Insatisfacible: N1+N2+N3 > T (assert)
% ============================================================
% Objetivo: verificar que el assert de satisfaccion.mzn detecta
% la imposibilidad ANTES de iniciar la búsqueda.
%
% Diseño:
%   - T=5 trabajadores, pero se piden 3+2+2=7 puestos por día.
%   - Es imposible cubrir un solo día. El assert debe dispararse
%     inmediatamente con el mensaje:
%     "No hay suficientes trabajadores para cubrir los turnos..."

D = 5;
T = 5;
N1 = 3;
N2 = 2;
N3 = 2;
MaxDT = 5;
MaxDL = 2;
MinDT = 1;
A = 0;

afines = [|false, true,  true,  true,  true
          |true,  false, true,  true,  true
          |true,  true,  false, true,  true
          |true,  true,  true,  false, true
          |true,  true,  true,  true,  false|];

R = {1, 2, 3};
